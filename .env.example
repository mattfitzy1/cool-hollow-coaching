# Cool Hollow Coaching - environment secrets. NEVER commit this file.
# Copy it to .env and fill in. You do NOT need every key to start. Each tool
# walks you through its own setup the first time you use it (or run /setup), and
# /doctor shows you what is still needed. Your keys live here, never in the chat.
#
# Nothing here is urgent. A skill that needs a key it cannot find will tell you
# which one and how to get it, then carry on - it never just breaks.

# -- Website + app hosting: Cloudflare Pages -- [needed to put a site or app live]
# Token:      https://dash.cloudflare.com  ->  My Profile  ->  API Tokens  ->  Create Token  ->  "Edit Cloudflare Pages"
# Account ID: Cloudflare dashboard  ->  Workers & Pages  ->  right sidebar
# Used by: cloudflare-pages, demo-video (to publish a video link)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# -- Image generation: Google Gemini (nano-banana) -- [free tier]
# https://aistudio.google.com/apikey
# Used by: nano-banana, creative   (your cheapest image tool, start here)
GEMINI_API_KEY=

# -- Creative / video engine: Higgsfield -- [PAID, about $59/mo. Set up only when you want AI video]
# https://higgsfield.ai  ->  pick a plan  ->  run `higgsfield auth login` (you log in, there is no key to paste)
# Used by: creative, marketing-video, demo-video   (the video pipeline + AI lesson video)
HIGGSFIELD_ENABLED=false
HF_MONTHLY_CAP=30

# -- Voiceover: ElevenLabs -- [for narrated walkthrough / ad videos; videos still render with music only if unset]
# https://elevenlabs.io/app/settings/api-keys
# Used by: demo-video, marketing-video
ELEVENLABS_API_KEY=

# -- Video transcripts + YouTube: Supadata -- [for the video pipeline, and turning a recorded call into a deck]
# https://supadata.ai/dashboard
# Used by: supadata, watch, podcast-search
SUPADATA_API_KEY=

# -- Spoken-audio fallback (Whisper) -- [only used by `watch` when a recording has NO captions]
# Set ONE (Groq preferred: free tier, faster).
# Groq: https://console.groq.com/keys   OpenAI: https://platform.openai.com/api-keys
GROQ_API_KEY=
OPENAI_API_KEY=

# -- Web research: Firecrawl -- [scrape / search / read any web page]
# https://www.firecrawl.dev/app/api-keys
# Used by: firecrawl, deep-research
FIRECRAWL_API_KEY=

# -- X / Twitter research: xAI (Grok) -- [what people are saying, real-time]
# https://console.x.ai
# Used by: x-search   (X_BEARER_TOKEN below is an optional extra for raw post metrics)
XAI_API_KEY=
X_BEARER_TOKEN=

# -- Academic / paper search: OpenAlex -- [no key needed; just an email for polite API use]
# Used by: academic
OPENALEX_EMAIL=

# -- Social posting: Publer -- [optional; for scheduling branded social posts]
# https://publer.com  ->  connect your account  ->  Settings  ->  Access  ->  API key
# Used by: schedule, publer_post.py   (always posts as a DRAFT for your approval)
PUBLER_API_KEY=

# -- Signing documents: your signature -- [for the `sign` skill, e.g. agreements]
# SIGNATURE_PATH = path to a PNG of your signature; SIGNER_NAME = your full name.
SIGNATURE_PATH=
SIGNER_NAME=

# -- Sending email -- [only if you wire up automated sends; needs Google sign-in on first run]
GMAIL_SENDER=
